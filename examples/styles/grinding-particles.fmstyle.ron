(
    version: 1,
    notes: Static((
        fill: Solid(Constant((255, 255, 255))),
        sheen: None,
        glow: None,
        roundedness: 1.0,
        fall_speed: 400.0,
        border: None,
        black_key_fill: Auto,
        alpha: Constant(1.0),
    )),
    barrier: Static((
        color: Constant((255, 255, 255)),
        thickness: 4.0,
        glow: None,
        pulse: None,
        wavy: None,
        show_bar: true,
    )),
    transition: Static((
        kind: Particles,
        particles: Some((
            count: 0,
            lifetime_seconds: Constant(0.45),
            size_px: Constant(6.0),
            speed_px: Constant(140.0),
            spread_degrees: Constant(100.0),
            gravity_px: Constant(250.0),
            color: Fixed(Constant((255, 210, 90))),
            additive: true,
            emission: Continuous(
                rate_per_second: 30.0,
            ),
            brightness: Constant(1.0),
            layers: ((
                amplitude: 2.6,
                sigma_px: 0.5,
            ), (
                amplitude: 1.1,
                sigma_px: 1.0,
            ), (
                amplitude: 0.38,
                sigma_px: 2.0,
            )),
        )),
        flash: None,
    )),
    background: Constant((0, 0, 0)),
)
